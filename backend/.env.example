NODE_ENV=development
STRICT_ENV=false
PORT=5000
HOST=::

# App URLs
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# JWT
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Uploads
UPLOAD_DIR=uploads

# Railway / MySQL
# Preferred on Railway:
# DATABASE_URL=${{MySQL.DATABASE_URL}}
# or MYSQL_URL / MYSQL_PRIVATE_URL if Railway injects those instead.
DATABASE_URL=
MYSQL_URL=
MYSQL_PRIVATE_URL=
MYSQL_PUBLIC_URL=

# Raw host/user/password fallback
MYSQLHOST=
MYSQLPORT=3306
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# DB startup tuning
DB_CONNECT_MAX_ATTEMPTS=12
DB_CONNECT_BASE_DELAY_MS=1000

# BullMQ / Redis (optional)
BULLMQ_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Razorpay (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PAYOUT_KEY_ID=
RAZORPAY_PAYOUT_KEY_SECRET=
RAZORPAY_PAYOUT_FUND_ACCOUNT_ID=
RAZORPAY_PAYOUT_SOURCE_ACCOUNT_NUMBER=

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional risk / payout tuning
RISK_AUTO_MITIGATE=false
PAYOUT_OPTIMIZER_ENABLED=false
FRAUD_AUTO_FREEZE=true
KYC_HIGH_WITHDRAWAL_INR=25000
KYC_TIER2_WITHDRAWAL_INR=50000
SCORING_MIN_WITHDRAW_SCORE=20
SCORING_CACHE_HOURS=24
EXPO_ACCESS_TOKEN=
