{
  "name": "meb-advanced-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node node_modules/typescript/bin/tsc",
    "start": "node dist/server.js",
    "seed": "tsx src/seed.ts",
    "db:migrate": "tsx src/scripts/db-migrate.ts",
    "db:migrate:plan": "tsx src/scripts/db-migrate.ts --plan",
    "db:migrate:adopt": "tsx src/scripts/db-migrate.ts --adopt",
    "db:bootstrap": "tsx src/scripts/db-migrate.ts --include-baseline"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.74.1",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.0",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.15.0",
    "razorpay": "^2.9.6",
    "typescript": "^5.0.0",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.4",
    "@types/pdfkit": "^0.13.5",
    "tsx": "^4.19.1"
  }
}
